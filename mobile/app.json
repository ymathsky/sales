{
  "expo": {
    "name": "Cash Flow",
    "slug": "cashflow-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mdofficesupport.cashflow",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Cash Flow to select receipt photos for your transactions.",
        "NSCameraUsageDescription": "Allow Cash Flow to take receipt photos for your transactions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.mdofficesupport.cashflow"
    }
  }
}
