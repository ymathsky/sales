<style>
.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
input[type="radio"]:checked + .type-card.type-in { background-color: #ecfdf5; border-color: #10b981; color: #047857; box-shadow: 0 0 0 1px #10b981; }
input[type="radio"]:checked + .type-card.type-out { background-color: #fef2f2; border-color: #ef4444; color: #b91c1c; box-shadow: 0 0 0 1px #ef4444; }
</style>

<script>
function updateTypeStyles() {
    // Styles are handled by CSS :checked selector
}

function updateFileCount(input) {
    const fileCount = input.files ? input.files.length : 0;
    const display = document.getElementById('file-count-display');
    
    if (fileCount > 0) {
        display.textContent = fileCount + ' file(s) selected';
        display.style.display = 'block';
    } else {
        display.style.display = 'none';
    }
}
</script>

